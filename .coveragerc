[run]
branch = True
source =
    main
    modules
omit =
    modules/*_LL.py
    modules/support/module_LL_template.py
    modules/support/module_fsm_template.py
    modules/support/smokeTest_Xtra2210.py
    modules/support/calibration_mpu6050.py
    modules/support/mpu6050_fusion.py
    modules/support/i2c_common.py

[report]
show_missing = True
skip_covered = True
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
